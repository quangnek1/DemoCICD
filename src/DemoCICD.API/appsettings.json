{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.AspNetCore.Authentication": "Debug"
            }
        }
    },
    "SqlServerRetryOptions": {
        "MaxRetryCount": 5,
        "MaxRetryDelay": "00:00:05",
        "ErrorNumbersToAdd": []
    },
    "AllowedHosts": "*"
}
